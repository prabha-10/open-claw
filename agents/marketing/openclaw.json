{
  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3-pro-preview"
      },
      "workspace": "agents/marketing",
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "perplexity",
        "apiKey": "${PERPLEXITY_API_KEY}" 
      }
    },
    "agentToAgent": {
      "enabled": true
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  }
}
